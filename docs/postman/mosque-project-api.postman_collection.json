              "raw": "{\n  \"name\": \"Summer Trip\",\n  \"date\": \"{{activity_date}}\",\n  \"image\": \"{{activity_image}}\",\n  \"activity_type\": \"{{activity_type}}\",\n  \"other_activity_type\": \"{{activity_other_type}}\",\n  \"attend_student_ids\": [{{student_id}}]\n}"
