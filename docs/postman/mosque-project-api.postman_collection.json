                "{{base_url}}"
              ],
              "path": [
                "api",
                "activities"
              ],
              "query": [
                {
                  "key": "activity_type",
                  "value": "{{activity_type}}"
                },
                {
                  "key": "date_from",
                  "value": "{{activity_date}}"
                }
              ]
            },
            "description": "Gets the activities visible to the authenticated user. Supported filters: activity_type, student_id, date_from, date_to."
